{
  "name": "harmonyos-guides-mcp",
  "version": "0.2.2",
  "description": "MCP server exposing HarmonyOS official development guides for API/Kit usage retrieval during development.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "harmonyos-guides-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
