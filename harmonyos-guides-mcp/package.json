    "prepack": "node scripts/copy-data.mjs && npm run build",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "selfcheck": "node scripts/selfcheck.mjs"
  },
  "keywords": [
    "harmonyos",
    "harmony",
    "arkts",
    "arkui",
