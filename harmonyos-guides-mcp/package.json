  "author": "2351548518",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2351548518/harmonyos-guides-mcp.git"
  },
  "homepage": "https://github.com/2351548518/harmonyos-guides-mcp",
  "bugs": {
    "url": "https://github.com/2351548518/harmonyos-guides-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
